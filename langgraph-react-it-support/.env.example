# watsonx credentials for LangGraph ReAct agent
WATSONX_APIKEY=your_watsonx_apikey
WATSONX_PROJECT_ID=your_watsonx_project_id
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# optional overrides
LANGGRAPH_MODEL_ID=ibm/granite-3-8b-instruct
LANGGRAPH_THREAD_ID=thread-1
LANGGRAPH_TICKETS_FILE=./data/tickets.csv

# optional: IBM Cloud Object Storage backend for tickets
LANGGRAPH_USE_COS=false
COS_ENDPOINT=
COS_INSTANCE_CRN=
COS_BUCKET_NAME=
COS_CSV_FILE_NAME=tickets.csv
